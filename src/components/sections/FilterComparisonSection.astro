---
import type { Locale } from "../../i18n/routes";
import { siteCopy } from "../../content/siteCopy";
import ThreeMethods from "../diagrams/ThreeMethods.astro";
import { FilterComparison } from "../interactive/FilterComparison";
import DeepDive from "../DeepDive.astro";
import RichText from "../RichText.astro";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const copy = siteCopy[locale];
const s = copy.sections.filters;
---

<section class="section" id="filters">
  <div class="section__inner">
    <p class="eyebrow">{s.eyebrow}</p>
    <RichText as="h2" class="section-title" text={s.heading} />
    <RichText class="lead" text={s.lead} />
    {s.body.map((paragraph) => <RichText text={paragraph} />)}

    <ThreeMethods labels={copy.diagrams.threeMethods} />

    <FilterComparison client:visible labels={copy.interactive.filterComparison} />

    {s.deepDive && <DeepDive deepDive={s.deepDive} />}
  </div>
</section>
