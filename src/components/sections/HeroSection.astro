---
import type { Locale } from "../../i18n/routes";
import { siteCopy } from "../../content/siteCopy";
import { withBasePath } from "../../lib/basePath";
import RichText from "../RichText.astro";
const { locale } = Astro.props as { locale: Locale };
const copy = siteCopy[locale];
---

<section class="section hero-section" id="top">
  <div class="section__inner hero-section__grid">
    <div>
      <p class="eyebrow">{copy.hero.eyebrow}</p>
      <RichText as="h1" class="section-title" text={copy.hero.title} />
      <RichText class="lead" text={copy.hero.intro} />
    </div>
    <figure class="hero-section__figure">
      <img src={withBasePath("/images/sun-h-alpha.png")} alt={copy.hero.imageAlt} fetchpriority="high" />
    </figure>
  </div>
</section>
