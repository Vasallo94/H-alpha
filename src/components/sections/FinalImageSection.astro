---
import type { Locale } from "../../i18n/routes";
import { siteCopy } from "../../content/siteCopy";
import RichText from "../RichText.astro";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props as { locale: Locale };
const copy = siteCopy[locale];
const fi = copy.finalImage;
---

<section class="section final-image-section" id="image">
  <div class="section__inner">
    <p class="eyebrow">{fi.eyebrow}</p>
    <RichText as="h2" class="section-title" text={fi.heading} />
    <RichText class="lead" text={fi.lead} />

    <figure class="final-image-section__figure">
      <div class="hotspot-wrap">
        <img
          src="/images/sun-h-alpha.png"
          alt={fi.imageAlt}
          loading="lazy"
          decoding="async"
        />
        <a
          class="sun-easter-egg sr-only"
          href={fi.instagramUrl}
          target="_blank"
          rel="noreferrer"
          tabindex="-1"
          aria-hidden="true"
        >
          {fi.instagramLabel}
        </a>
        {fi.annotations.map((a) => (
          <button
            class="hotspot"
            style={`left:${a.x}%; top:${a.y}%`}
            aria-label={a.label}
          >
            <span class="hotspot__dot" aria-hidden="true"></span>
            <span class="hotspot__popover" role="tooltip">
              <RichText as="strong" text={a.label} />
              <RichText as="span" text={a.description} />
            </span>
          </button>
        ))}
      </div>
      <figcaption>{fi.caption}</figcaption>
    </figure>
  </div>
</section>
