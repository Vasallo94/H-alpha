---
import type { Locale } from "../../i18n/routes";
import { siteCopy } from "../../content/siteCopy";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const safety = siteCopy[locale].safety;
const seasonal = safety.seasonalCallout;
const seasonalSafetyTitleId = `seasonal-safety-title-${locale}`;
---

<section class="section" id="safety">
  <div class="section__inner">
    <p class="eyebrow">{safety.eyebrow}</p>
    <h2 class="section-title">{safety.heading}</h2>
    <ul class="safety-rules">
      {
        safety.rules.map((rule) => (
          <li class="safety-rules__item">
            <h3>{rule.title}</h3>
            <p>{rule.body}</p>
          </li>
        ))
      }
    </ul>
    {
      seasonal.enabled && (
        <aside class="warning" role="note" aria-labelledby={seasonalSafetyTitleId}>
          <h3 id={seasonalSafetyTitleId}>{seasonal.title}</h3>
          <p>{seasonal.body}</p>
        </aside>
      )
    }
  </div>
</section>
