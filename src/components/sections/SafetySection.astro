---
import type { Locale } from "../../i18n/routes";
import { siteCopy } from "../../content/siteCopy";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const copy = siteCopy[locale];
const safety = copy.sections.safety;
const seasonalSafetyTitleId = `seasonal-safety-title-${locale}`;
---

<section class="section" id="safety">
  <div class="section__inner">
    <p class="eyebrow">{safety.eyebrow}</p>
    <h2 class="section-title">{safety.heading}</h2>
    {
      copy.seasonalSafetyCallout.enabled && (
        <aside class="warning" role="note" aria-labelledby={seasonalSafetyTitleId}>
          <h3 id={seasonalSafetyTitleId}>{copy.seasonalSafetyCallout.title}</h3>
          <p>{copy.seasonalSafetyCallout.body}</p>
        </aside>
      )
    }
  </div>
</section>
