---
import type { Locale } from "../../i18n/routes";
import { siteCopy } from "../../content/siteCopy";
import GlossaryTerm from "../GlossaryTerm.astro";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const copy = siteCopy[locale];
const spectrum = copy.sections.spectrum;
const bandpass = copy.glossary.bandpass;
---

<section class="section" id="spectrum">
  <div class="section__inner">
    <p class="eyebrow">{spectrum.eyebrow}</p>
    <h2 class="section-title">{spectrum.heading}</h2>
    <p class="lead">
      {spectrum.leadStart}<GlossaryTerm {...bandpass} id="bandpass-spectrum">{bandpass.term}</GlossaryTerm>{spectrum.leadEnd}
    </p>
  </div>
</section>
