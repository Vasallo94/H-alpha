---
import type { Locale } from "../../i18n/routes";
import { siteCopy } from "../../content/siteCopy";
import OpticalChain from "../diagrams/OpticalChain.astro";
import DeepDive from "../DeepDive.astro";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const copy = siteCopy[locale];
const s = copy.sections.opticalSystem;
---

<section class="section" id="optics">
  <div class="section__inner">
    <p class="eyebrow">{s.eyebrow}</p>
    <h2 class="section-title">{s.heading}</h2>
    <p class="lead">{s.lead}</p>
    {s.body.map((paragraph) => <p>{paragraph}</p>)}

    <OpticalChain labels={copy.diagrams.opticalChain} />

    {s.deepDive && <DeepDive deepDive={s.deepDive} />}
  </div>
</section>
