---
import type { Locale } from "../i18n/routes";
import { siteCopy } from "../content/siteCopy";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const social = siteCopy[locale].social;
---
<footer class="site-footer">
  <div class="site-footer__inner">
    <p>{social.byline}</p>
    <nav class="site-footer__links" aria-label="Social">
      <a href={social.githubUrl} target="_blank" rel="noreferrer">{social.github}</a>
      <a href={social.linkedinUrl} target="_blank" rel="noreferrer">{social.linkedin}</a>
    </nav>
  </div>
</footer>
