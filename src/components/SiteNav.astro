---
import { getLocalizedPath, type Locale } from "../i18n/routes";
import { siteCopy } from "../content/siteCopy";
import LanguageToggle from "./LanguageToggle.astro";

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const copy = siteCopy[locale];
const navAriaLabel = locale === "es" ? "Principal" : "Primary";
---

<header class="site-nav">
  <a class="site-nav__brand" href={getLocalizedPath(locale)}>H-alpha</a>
  <nav aria-label={navAriaLabel}>
    <a href="#origin">{copy.nav.origin}</a>
    <a href="#spectrum">{copy.nav.etalon}</a>
    <a href="#tuning">{copy.nav.tuning}</a>
    <a href="#safety">{copy.nav.safety}</a>
    <a href="#image">{copy.nav.image}</a>
  </nav>
  <LanguageToggle locale={locale} label={copy.languageLabel} />
</header>
