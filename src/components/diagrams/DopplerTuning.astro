---
interface Props { labels: Record<string, string> }
const { labels } = Astro.props;

const x0 = 62;
const x1 = 594;
const axisY = 258;
const continuumY = 112;
const troughY = 232;
const center = 328;
const blue = 230;
const red = 426;
const windowW = 46;
const windowTop = 88;
const windowBottom = axisY;
const blueCol = "#2f6fd0";

const lineProfile = `
  M ${x0} ${continuumY}
  C 160 ${continuumY} 220 ${continuumY + 2} 262 164
  C 286 ${troughY} 370 ${troughY} 394 164
  C 436 ${continuumY + 2} 500 ${continuumY} ${x1} ${continuumY}
`;

const windowPath = (cx: number, y = windowTop + 16, h = 36) =>
  `M ${cx - windowW / 2} ${y + h} C ${cx - 12} ${y + h} ${cx - 8} ${y} ${cx} ${y} C ${cx + 8} ${y} ${cx + 12} ${y + h} ${cx + windowW / 2} ${y + h}`;
---
<figure class="diagram">
  <svg viewBox="0 0 640 380" role="img" aria-label={labels.aria}>
    <defs>
      <marker id="dt-arrow" markerWidth="9" markerHeight="9" refX="6" refY="3" orient="auto">
        <path d="M0,0 L6,3 L0,6 Z" fill="var(--ink)" />
      </marker>
      <marker id="dt-arrow-blue" markerWidth="9" markerHeight="9" refX="6" refY="3" orient="auto">
        <path d="M0,0 L6,3 L0,6 Z" fill={blueCol} />
      </marker>
      <marker id="dt-arrow-red" markerWidth="9" markerHeight="9" refX="6" refY="3" orient="auto">
        <path d="M0,0 L6,3 L0,6 Z" fill="var(--solar-deep)" />
      </marker>
    </defs>

    <!-- Wavelength axis -->
    <line x1={x0} y1={axisY} x2={x1} y2={axisY} stroke="var(--ink)" stroke-width="1.3" marker-end="url(#dt-arrow)" />
    <text x={x1 - 4} y={axisY + 24} font-size="12.5" fill="var(--ink)" text-anchor="end">{labels.wavelengthAxis}</text>

    <!-- Absorption profile of the Hα line: center and wings are the terrain the etalon samples. -->
    <path d={lineProfile} fill="none" stroke="var(--instrument)" stroke-width="3" stroke-linecap="round" />
    <text x={center} y={continuumY - 22} font-size="14" font-weight="700" fill="var(--instrument)" text-anchor="middle">{labels.lineLabel}</text>

    <!-- Three possible positions of the same narrow etalon window. -->
    <g opacity="0.7">
      <rect x={blue - windowW / 2} y={windowTop} width={windowW} height={windowBottom - windowTop} fill={blueCol} opacity="0.1" />
      <line x1={blue - windowW / 2} y1={windowTop} x2={blue - windowW / 2} y2={windowBottom} stroke={blueCol} stroke-width="1.1" stroke-dasharray="4 3" />
      <line x1={blue + windowW / 2} y1={windowTop} x2={blue + windowW / 2} y2={windowBottom} stroke={blueCol} stroke-width="1.1" stroke-dasharray="4 3" />
      <path d={windowPath(blue)} fill="none" stroke={blueCol} stroke-width="1.8" />
    </g>

    <rect x={center - windowW / 2} y={windowTop} width={windowW} height={windowBottom - windowTop} fill="var(--solar)" opacity="0.13" />
    <line x1={center - windowW / 2} y1={windowTop} x2={center - windowW / 2} y2={windowBottom} stroke="var(--solar)" stroke-width="1.2" stroke-dasharray="4 3" />
    <line x1={center + windowW / 2} y1={windowTop} x2={center + windowW / 2} y2={windowBottom} stroke="var(--solar)" stroke-width="1.2" stroke-dasharray="4 3" />
    <path d={windowPath(center, windowTop + 8, 44)} fill="none" stroke="var(--solar)" stroke-width="2.6" />

    <g opacity="0.7">
      <rect x={red - windowW / 2} y={windowTop} width={windowW} height={windowBottom - windowTop} fill="var(--solar-deep)" opacity="0.09" />
      <line x1={red - windowW / 2} y1={windowTop} x2={red - windowW / 2} y2={windowBottom} stroke="var(--solar-deep)" stroke-width="1.1" stroke-dasharray="4 3" />
      <line x1={red + windowW / 2} y1={windowTop} x2={red + windowW / 2} y2={windowBottom} stroke="var(--solar-deep)" stroke-width="1.1" stroke-dasharray="4 3" />
      <path d={windowPath(red)} fill="none" stroke="var(--solar-deep)" stroke-width="1.8" />
    </g>

    <text x={center} y={windowTop - 14} font-size="13" font-weight="700" fill="var(--solar-deep)" text-anchor="middle">{labels.windowLabel}</text>

    <!-- Ticks and labels: center = disk detail; wings = Doppler-shifted material. -->
    <line x1={blue} y1={axisY} x2={blue} y2={axisY + 8} stroke={blueCol} stroke-width="1.4" />
    <line x1={center} y1={axisY} x2={center} y2={axisY + 8} stroke="var(--solar)" stroke-width="1.4" />
    <line x1={red} y1={axisY} x2={red} y2={axisY + 8} stroke="var(--solar-deep)" stroke-width="1.4" />

    <text x={blue} y={axisY + 43} font-size="12.5" fill={blueCol} font-weight="700" text-anchor="middle">{labels.blueshift}</text>
    <text x={center} y={axisY + 43} font-size="12.5" fill="var(--solar-deep)" font-weight="700" text-anchor="middle">{labels.centerLabel}</text>
    <text x={red} y={axisY + 43} font-size="12.5" fill="var(--solar-deep)" font-weight="700" text-anchor="middle">{labels.redshift}</text>

    <line x1={blue - 10} y1={axisY + 54} x2={blue - 54} y2={axisY + 76} stroke={blueCol} stroke-width="1" marker-end="url(#dt-arrow-blue)" />
    <text x={blue - 60} y={axisY + 82} font-size="12.5" fill={blueCol} text-anchor="end">{labels.approachingGas}</text>

    <line x1={center} y1={axisY + 54} x2={center} y2={axisY + 74} stroke="var(--muted)" stroke-width="1" />
    <text x={center} y={axisY + 88} font-size="12.5" fill="var(--muted)" text-anchor="middle">{labels.diskDetail}</text>

    <line x1={red + 10} y1={axisY + 54} x2={red + 54} y2={axisY + 76} stroke="var(--solar-deep)" stroke-width="1" marker-end="url(#dt-arrow-red)" />
    <text x={red + 60} y={axisY + 82} font-size="12.5" fill="var(--solar-deep)" text-anchor="start">{labels.recedingGas}</text>

    <text x={(x0 + x1) / 2} y="372" font-size="12.5" fill="var(--muted)" text-anchor="middle">{labels.wingLabel}</text>
  </svg>
  <figcaption>{labels.caption}</figcaption>
</figure>
