---
interface Props { labels: Record<string, string> }
const { labels } = Astro.props;
// Quarter cross-section: nested arcs centred at bottom-left. Each layer is a band; every
// label lives in a clean column on the right with a leader line to its band. No crossings.
const cx = 40;
const cy = 360;
const a0 = -2 * (Math.PI / 180);   // start angle (near horizontal)
const a1 = -92 * (Math.PI / 180);  // end angle (near vertical)
const arc = (r: number) => {
  const x0 = cx + r * Math.cos(a0);
  const y0 = cy + r * Math.sin(a0);
  const x1 = cx + r * Math.cos(a1);
  const y1 = cy + r * Math.sin(a1);
  return `M ${x0.toFixed(1)} ${y0.toFixed(1)} A ${r} ${r} 0 0 0 ${x1.toFixed(1)} ${y1.toFixed(1)}`;
};
const at = (r: number, deg: number) => {
  const a = deg * (Math.PI / 180);
  return { x: cx + r * Math.cos(a), y: cy + r * Math.sin(a) };
};
// Radii (px). Interior solar body, then the three named layers.
const rPhoto = 200;   // top of photosphere
const rChromo = 232;  // top of chromosphere (thin band, emphasised)
const rCorona = 360;  // top of corona

// Band mid-radii for leader anchor points (all at a shared angle so leaders fan out cleanly).
const anchorDeg = -30;
const aPhoto = at(rPhoto * 0.7, anchorDeg);
const aChromo = at((rPhoto + rChromo) / 2, anchorDeg);
const aCorona = at((rChromo + rCorona) / 2, anchorDeg);

// Label column on the right. Each row: title + note, vertically separated.
const colX = 430;
const rowPhoto = 320;
const rowChromo = 196;
const rowCorona = 96;
---
<figure class="diagram">
  <svg viewBox="0 0 620 420" role="img" aria-label={labels.aria}>
    <defs>
      <marker id="sl-dot" markerWidth="7" markerHeight="7" refX="3.5" refY="3.5">
        <circle cx="3.5" cy="3.5" r="2.4" fill="currentColor" />
      </marker>
      <marker id="sl-arrow" markerWidth="9" markerHeight="9" refX="6" refY="3" orient="auto">
        <path d="M0,0 L6,3 L0,6 Z" fill="currentColor" />
      </marker>
    </defs>

    <!-- Corona (faint outer band) -->
    <path d={arc((rChromo + rCorona) / 2)} fill="none" stroke="#f0d9b5" stroke-width={rCorona - rChromo} opacity="0.4" />
    <!-- Interior + photosphere (bright solar body) -->
    <path d={`M ${cx} ${cy - rPhoto} A ${rPhoto} ${rPhoto} 0 0 0 ${cx - rPhoto} ${cy} L ${cx} ${cy} Z`} fill="#f3b14a" />
    <path d={`M ${cx} ${cy - rPhoto * 0.6} A ${rPhoto * 0.6} ${rPhoto * 0.6} 0 0 0 ${cx - rPhoto * 0.6} ${cy} L ${cx} ${cy} Z`} fill="#e8902e" opacity="0.7" />
    <!-- Chromosphere band: the H-alpha layer, in the --solar family -->
    <path d={arc((rPhoto + rChromo) / 2)} fill="none" stroke="var(--solar)" stroke-width={rChromo - rPhoto} opacity="0.95" />

    <!-- Boundary arcs -->
    <path d={arc(rPhoto)} fill="none" stroke="var(--ink)" stroke-width="0.8" opacity="0.35" />
    <path d={arc(rChromo)} fill="none" stroke="var(--solar-deep)" stroke-width="1" />
    <path d={arc(rCorona)} fill="none" stroke="#d8b98a" stroke-width="0.8" opacity="0.7" />

    <!-- ===== Layer labels: clean right column, leaders to each band ===== -->

    <!-- Photosphere -->
    <g color="#7a4a12">
      <line x1={aPhoto.x} y1={aPhoto.y} x2={colX - 8} y2={rowPhoto - 5} stroke="currentColor" stroke-width="1" marker-start="url(#sl-dot)" />
    </g>
    <text x={colX} y={rowPhoto} font-size="15" fill="#7a4a12" font-weight="700">{labels.photosphere}</text>
    <text x={colX} y={rowPhoto + 17} font-size="12" fill="var(--muted)">{labels.photosphereNote}</text>
    <text x={colX} y={rowPhoto + 36} font-size="12.5" fill="var(--ink)" font-weight="700">{labels.whiteLightLabel}</text>

    <!-- Chromosphere -->
    <g color="var(--solar-deep)">
      <line x1={aChromo.x} y1={aChromo.y} x2={colX - 8} y2={rowChromo - 5} stroke="currentColor" stroke-width="1" marker-start="url(#sl-dot)" />
    </g>
    <text x={colX} y={rowChromo} font-size="15" fill="var(--solar-deep)" font-weight="700">{labels.chromosphere}</text>
    <text x={colX} y={rowChromo + 17} font-size="12" fill="var(--muted)">{labels.chromosphereNote}</text>
    <text x={colX} y={rowChromo + 36} font-size="12.5" fill="var(--solar)" font-weight="700">{labels.hAlphaLabel}</text>

    <!-- Corona -->
    <g color="var(--muted)">
      <line x1={aCorona.x} y1={aCorona.y} x2={colX - 8} y2={rowCorona - 5} stroke="currentColor" stroke-width="1" marker-start="url(#sl-dot)" />
    </g>
    <text x={colX} y={rowCorona} font-size="15" fill="var(--muted)" font-weight="700">{labels.corona}</text>
    <text x={colX} y={rowCorona + 17} font-size="12" fill="var(--muted)">{labels.coronaNote}</text>
  </svg>
  <figcaption>{labels.caption}</figcaption>
</figure>
