---
import type { Locale } from "../i18n/routes";
import { getLocalizedPath } from "../i18n/routes";

interface Props {
  locale: Locale;
  label: string;
}

const { locale, label } = Astro.props;
const targetLocale = locale === "es" ? "en" : "es";
const ariaLabel = targetLocale === "en" ? "Switch to English" : "Cambiar a español";
---

<a class="language-toggle" href={getLocalizedPath(targetLocale)} aria-label={ariaLabel} lang={targetLocale} hreflang={targetLocale}>
  {label}
</a>
